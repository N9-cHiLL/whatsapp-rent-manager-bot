# Copy to .env and fill in values (never commit .env)

# Google AI Studio / Gemini
GEMINI_API_KEY=

# Twilio (Console → Account SID & Auth Token; Sandbox "From" is whatsapp:+14155238886)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Google Sheet containing tab "Rent Ledger" — ID from the sheet URL
SPREADSHEET_ID=
# Optional: separate spreadsheet ID for tab "Center Config"
# If empty, Center Config is read from SPREADSHEET_ID
CENTER_CONFIG_SPREADSHEET_ID=

# Service account JSON path (recommended) OR paste JSON into GOOGLE_SERVICE_ACCOUNT_JSON
GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account.json
# GOOGLE_SERVICE_ACCOUNT_JSON=

# Optional: gemini-2.5-flash is default
# GEMINI_MODEL=gemini-2.5-flash

# Optional Twilio signature check (needs PUBLIC_BASE_URL = your ngrok https URL, no trailing slash)
# VALIDATE_TWILIO_SIGNATURE=false
# PUBLIC_BASE_URL=https://xxxx.ngrok.io

# Required if you want to use POST /admin/refresh-center-config
CENTER_CONFIG_REFRESH_TOKEN=
